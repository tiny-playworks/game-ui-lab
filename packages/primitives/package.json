{
  "name": "@tiny-playworks/game-ui",
  "version": "0.2.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "codegen": "pnpm --dir ../.. exec panda codegen",
    "build:styles": "node ./scripts/build-styles.mjs",
    "build": "pnpm run codegen && rslib build && pnpm run build:styles",
    "test": "pnpm --filter @tiny-playworks/tokens build && pnpm run codegen && rstest run",
    "typecheck": "pnpm run codegen && tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@tiny-playworks/tokens": "workspace:^",
    "motion": "^12.38.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.21.5",
    "@rstest/core": "^0.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@tiny-playworks/styled-system": "workspace:*",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "happy-dom": "^20.0.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^6.0.3"
  }
}
