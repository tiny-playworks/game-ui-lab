{
  "name": "@tiny-playworks/game-ui-gallery",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @tiny-playworks/game-ui build && rsbuild dev --open",
    "build": "pnpm --filter @tiny-playworks/game-ui build && rsbuild build",
    "build:pages": "node ./scripts/build-pages.mjs",
    "preview": "rsbuild preview",
    "test": "rstest run",
    "typecheck": "pnpm --filter @tiny-playworks/game-ui build && tsc --noEmit",
    "visual:smoke": "node ./scripts/smoke-gallery.mjs"
  },
  "dependencies": {
    "@tiny-playworks/game-ui": "workspace:*",
    "@tiny-playworks/tokens": "workspace:*",
    "motion": "^12.38.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.5.10",
    "@rsbuild/plugin-react": "^1.4.1",
    "@rstest/core": "^0.9.9",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "typescript": "^5.8.3"
  }
}
